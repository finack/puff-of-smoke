                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*remix dev.*",
                    "endsPattern": "^.*Local environment ready.*"
                }
            },
			"label": "npm: dev",
			"detail": "remix dev --manual -c \"arc sandbox -e testing\"",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "new",
				"showReuseMessage": true,
				"clear": false
			}
		}
	]
}